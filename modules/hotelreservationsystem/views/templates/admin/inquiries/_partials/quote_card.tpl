<div class="inquiry-quote-item" data-role="quote-item">
    <div class="inquiry-quote-item-header">
        <span class="label label-default" data-field="status-label"></span>
        <strong class="inquiry-quote-total" data-field="total-display"></strong>
    </div>
    <div class="inquiry-quote-item-body">
        <div class="inquiry-quote-meta" data-field="meta"></div>
        <div class="inquiry-quote-actions">
            <div class="inquiry-quote-status-actions" data-role="status-actions">
                <button type="button" class="btn btn-success btn-xs" data-action="approve-quote">
                    <i class="icon-check"></i> {l s='Approve' mod='hotelreservationsystem'}
                </button>
                <button type="button" class="btn btn-danger btn-xs" data-action="decline-quote">
                    <i class="icon-remove"></i> {l s='Decline' mod='hotelreservationsystem'}
                </button>
            </div>
            <div class="inquiry-quote-delivery-actions" data-role="delivery-actions">
                <button type="button" class="btn btn-default btn-xs" data-action="download-quote">
                    <i class="icon-download"></i> {l s='Download PDF' mod='hotelreservationsystem'}
                </button>
                <button type="button" class="btn btn-default btn-xs" data-action="email-quote">
                    <i class="icon-envelope"></i> {l s='Email to guest' mod='hotelreservationsystem'}
                </button>
            </div>
        </div>
    </div>
</div>
